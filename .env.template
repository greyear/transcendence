# Global environment template
# Copy to .env in project root if needed.

# Common
NODE_ENV="development"

# API Gateway
API_GATEWAY_PORT="3000"
AUTH_SERVICE_URL="http://auth-service:3001"
CORE_SERVICE_URL="http://core-service:3002"
NOTIFICATION_SERVICE_URL="http://notification-service:3003"

# Auth service
AUTH_SERVICE_PORT="3001"
MONGODB_URI="mongodb://root:rootpassword@auth-db:27017/auth_db?authSource=admin"
JWT_SECRET="change-me"

# Core service
CORE_SERVICE_PORT="3002"
DATABASE_URL_CORE="postgresql://core_user:core_password@core-db:5432/core_db"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_DB="core_db"
POSTGRES_USER="core_user"
POSTGRES_PASSWORD="core_password"

# Notification service
NOTIFICATION_SERVICE_PORT="3003"
DATABASE_URL_NOTIFICATION="postgresql://notification_user:notification_password@notification-db:5432/notification_db"

# Databases
MONGO_ROOT_USERNAME="root"
MONGO_ROOT_PASSWORD="rootpassword"
CORE_POSTGRES_DB="core_db"
CORE_POSTGRES_USER="core_user"
CORE_POSTGRES_PASSWORD="core_password"
NOTIFICATION_POSTGRES_DB="notification_db"
NOTIFICATION_POSTGRES_USER="notification_user"
NOTIFICATION_POSTGRES_PASSWORD="notification_password"
